{
  "name": "expo-geocoding",
  "version": "0.1.0",
  "description": "Zero-config Expo-first geocoding SDK with Nominatim, caching, hooks, and autocomplete.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "files": ["build"],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "npm run build",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "expo",
    "react-native",
    "geocoding",
    "reverse-geocoding",
    "nominatim",
    "openstreetmap",
    "osm",
    "places",
    "autocomplete",
    "location",
    "maps",
    "expo-geocoding",
    "expo-module"
  ],
  "repository": "https://github.com/krmll4444/expo-geocoding",
  "bugs": {
    "url": "https://github.com/krmll4444/expo-geocoding/issues"
  },
  "author": "krmll4444 <saffaryday@gmail.com> (https://github.com/krmll4444)",
  "license": "MIT",
  "homepage": "https://github.com/krmll4444/expo-geocoding#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.1.1",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.24",
    "react-native": "0.82.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
